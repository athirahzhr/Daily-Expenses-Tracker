{"files":[{"id":"6f8fab28-e1f4-4af4-947d-10a7ec734bf8","name":"appsscript","type":"json","source":"{\n  \"timeZone\": \"Asia/Singapore\",\n  \"dependencies\": {},\n  \"exceptionLogging\": \"STACKDRIVER\",\n  \"runtimeVersion\": \"V8\",\n  \"webapp\": {\n    \"executeAs\": \"USER_DEPLOYING\",\n    \"access\": \"ANYONE_ANONYMOUS\"\n  }\n}"},{"id":"1c8e923c-28ef-41cf-8e34-c81e2747535f","name":"Code","type":"server_js","source":"const SHEET_NAME \u003d \"DailyExpenses\";\nconst SHEET_ID \u003d \"1rXoXznV4mFD_UWg-becwc9sRkl9-pcdjOPP6awKy8pg\"; // Your sheet ID\n\nfunction doGet() {\n  return HtmlService.createHtmlOutputFromFile(\"Index\")\n      .setTitle(\"Daily Expense Tracker\");\n}\n\n// \u003d\u003d\u003d\u003d\u003d UTIL \u003d\u003d\u003d\u003d\u003d\nfunction getSheet() {\n  const ss \u003d SpreadsheetApp.openById(SHEET_ID);\n  let sheet \u003d ss.getSheetByName(SHEET_NAME);\n  if (!sheet) {\n    // Create sheet if it doesn\u0027t exist\n    sheet \u003d ss.insertSheet(SHEET_NAME);\n    sheet.appendRow([\"Date\", \"Amount\", \"Category\", \"Notes\"]);\n  }\n  return sheet;\n}\n\n// \u003d\u003d\u003d\u003d\u003d ADD EXPENSE \u003d\u003d\u003d\u003d\u003d\nfunction addExpense(date, amount, category, notes) {\n  const sheet \u003d getSheet();\n  sheet.appendRow([new Date(date), Number(amount), category, notes]);\n  return true;\n}\n\n// \u003d\u003d\u003d\u003d\u003d GET EXPENSES \u003d\u003d\u003d\u003d\u003d\nfunction getExpenses() {\n  const sheet \u003d getSheet();\n  const data \u003d sheet.getDataRange().getValues();\n  if (data.length \u003c\u003d 1) return [];\n\n  return data.slice(1).map(row \u003d\u003e ({\n    date: row[0] instanceof Date ? Utilities.formatDate(row[0], Session.getScriptTimeZone(), \"yyyy-MM-dd\") : row[0],\n    amount: Number(row[1]),\n    category: row[2],\n    notes: row[3]\n  }));\n}\n"},{"id":"8ca7cdcc-c73a-4e81-b475-782bbb40ad09","name":"Index","type":"html","source":"\u003c!DOCTYPE html\u003e\n\u003chtml\u003e\n\u003chead\u003e\n  \u003cbase target\u003d\"_top\"\u003e\n  \u003cscript src\u003d\"https://cdn.jsdelivr.net/npm/chart.js\"\u003e\u003c/script\u003e\n  \u003cstyle\u003e\n    /* ----- Body \u0026 Headings ----- */\n    body {\n      font-family: \u0027Segoe UI\u0027, sans-serif;\n      margin: 0;\n      padding: 0;\n      background: linear-gradient(135deg, #e6d0f7, #d0e0ff, #d0f7f2);\n      min-height: 100vh;\n      color: #333;\n    }\n    h2 {\n      text-align: center;\n      margin: 20px 0;\n      font-size: 2em;\n      color: #1a237e;\n      text-shadow: 1px 1px 2px rgba(0,0,0,0.1);\n    }\n    h3 {\n      margin-bottom: 15px;\n      color: #3949ab;\n    }\n\n    /* ----- Card Layout ----- */\n    .card {\n      background: #fff;\n      margin: 20px auto;\n      padding: 25px;\n      max-width: 900px;\n      border-radius: 20px;\n      box-shadow: 0 10px 25px rgba(0,0,0,0.15);\n      transition: transform 0.3s;\n    }\n    .card:hover {\n      transform: translateY(-5px);\n    }\n\n    /* ----- Flex Containers ----- */\n    .flex {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 15px;\n      justify-content: center;\n      align-items: center;\n      margin-bottom: 10px;\n    }\n\n    /* ----- Inputs \u0026 Buttons ----- */\n    input, select, button {\n      padding: 12px 16px;\n      border-radius: 12px;\n      border: 1px solid #ccc;\n      font-size: 1em;\n      transition: 0.3s;\n    }\n    input:focus, select:focus {\n      border-color: #3f51b5;\n      outline: none;\n      box-shadow: 0 0 5px rgba(63,81,181,0.3);\n    }\n    button {\n      cursor: pointer;\n      background: linear-gradient(135deg,#4caf50,#66bb6a);\n      color: white;\n      border: none;\n      font-weight: bold;\n      transition: 0.3s;\n    }\n    button:hover {\n      background: linear-gradient(135deg,#388e3c,#43a047);\n      transform: translateY(-2px);\n    }\n\n    /* ----- Charts (Glassmorphism) ----- */\n    #chartContainer, #pieContainer {\n      width: 100%;\n      margin: 20px auto;\n      padding: 25px;\n      background: rgba(255,255,255,0.3);\n      border-radius: 20px;\n      box-shadow: 0 8px 20px rgba(0,0,0,0.1);\n      backdrop-filter: blur(10px);\n      -webkit-backdrop-filter: blur(10px);\n      border: 1px solid rgba(255,255,255,0.4);\n    }\n\n    /* ----- Weekly Limit Warning ----- */\n    .warning {\n      color: white;\n      background: #e53935;\n      padding: 14px;\n      border-radius: 12px;\n      margin: 15px auto;\n      text-align: center;\n      font-weight: bold;\n      display: none;\n      animation: flash 0.5s;\n      max-width: 400px;\n    }\n    @keyframes flash { 0%{opacity:0} 50%{opacity:1} 100%{opacity:0} }\n\n    /* ----- Comparison Info ----- */\n    #comparison {\n      text-align: center;\n      font-weight: bold;\n      font-size: 1.1em;\n      margin-top: 12px;\n    }\n    .higher { color: #d32f2f; }\n    .lower { color: #388e3c; }\n\n    /* ----- Table Styling ----- */\n    table {\n      width: 100%;\n      border-collapse: collapse;\n      margin-top: 15px;\n      font-size: 0.95em;\n    }\n    th, td {\n      border: 1px solid #ccc;\n      padding: 10px;\n      text-align: center;\n      transition: background 0.3s;\n    }\n    th {\n      background: #3f51b5;\n      color: white;\n    }\n    tr:hover {\n      background: #e8eaf6;\n    }\n\n    /* ----- Category Totals ----- */\n    #categoryTotals {\n      margin-top: 12px;\n      text-align: center;\n      font-weight: bold;\n      font-size: 1.05em;\n      color: #3949ab;\n    }\n\n    /* ----- Responsive ----- */\n    @media(max-width:800px){\n      .flex { flex-direction: column; }\n      input, select, button { width: 80%; }\n    }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\n\u003ch2\u003e💰 Daily Expenses Tracker\u003c/h2\u003e\n\n\u003c!-- ADD EXPENSE --\u003e\n\u003cdiv class\u003d\"card\"\u003e\n  \u003ch3\u003eAdd Daily Expense\u003c/h3\u003e\n  \u003cdiv class\u003d\"flex\"\u003e\n    \u003cinput type\u003d\"date\" id\u003d\"date\" required\u003e\n    \u003cinput type\u003d\"number\" id\u003d\"amount\" placeholder\u003d\"Amount\" required\u003e\n    \u003cselect id\u003d\"category\"\u003e\n      \u003coption value\u003d\"\"\u003eSelect Category\u003c/option\u003e\n      \u003coption value\u003d\"Food\"\u003eFood\u003c/option\u003e\n      \u003coption value\u003d\"Transport\"\u003eTransport\u003c/option\u003e\n      \u003coption value\u003d\"Entertainment\"\u003eEntertainment\u003c/option\u003e\n      \u003coption value\u003d\"Laundry\"\u003eLaundry\u003c/option\u003e\n      \u003coption value\u003d\"Shopping\"\u003eShopping\u003c/option\u003e\n    \u003c/select\u003e\n    \u003cinput type\u003d\"text\" id\u003d\"notes\" placeholder\u003d\"Notes\"\u003e\n    \u003cbutton onclick\u003d\"addExpense()\"\u003eAdd\u003c/button\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003c!-- WEEKLY LIMIT --\u003e\n\u003cdiv class\u003d\"card\"\u003e\n  \u003ch3\u003eWeekly Limit\u003c/h3\u003e\n  \u003cdiv class\u003d\"flex\"\u003e\n    \u003cinput type\u003d\"number\" id\u003d\"weeklyLimit\" placeholder\u003d\"Set weekly limit\" value\u003d\"100\"\u003e\n    \u003cbutton onclick\u003d\"setLimit()\"\u003eSet Limit\u003c/button\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003cdiv id\u003d\"warning\" class\u003d\"warning\"\u003e⚠ Weekly limit exceeded!\u003c/div\u003e\n\n\u003c!-- CHART --\u003e\n\u003cdiv class\u003d\"card\"\u003e\n  \u003ch3\u003eExpenses Chart\u003c/h3\u003e\n  \u003cdiv class\u003d\"flex\"\u003e\n    \u003clabel\u003eView:\u003c/label\u003e\n    \u003cselect id\u003d\"viewSelect\" onchange\u003d\"renderChart()\"\u003e\n      \u003coption value\u003d\"daily\"\u003eDaily\u003c/option\u003e\n      \u003coption value\u003d\"weekly\"\u003eWeekly\u003c/option\u003e\n      \u003coption value\u003d\"monthly\"\u003eMonthly\u003c/option\u003e\n    \u003c/select\u003e\n    \u003cbutton onclick\u003d\"printExpenses()\"\u003ePrint\u003c/button\u003e\n  \u003c/div\u003e\n  \u003cdiv id\u003d\"chartContainer\"\u003e\n    \u003ccanvas id\u003d\"expenseChart\"\u003e\u003c/canvas\u003e\n    \u003cdiv id\u003d\"comparison\"\u003e\u003c/div\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003c!-- PIE CHART --\u003e\n\u003cdiv class\u003d\"card\"\u003e\n  \u003ch3\u003eCategory Distribution\u003c/h3\u003e\n  \u003cdiv id\u003d\"pieContainer\"\u003e\n    \u003ccanvas id\u003d\"pieChart\"\u003e\u003c/canvas\u003e\n    \u003cdiv id\u003d\"categoryTotals\"\u003e\u003c/div\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\u003c!-- TABLE --\u003e\n\u003cdiv class\u003d\"card\"\u003e\n  \u003ch3\u003eExpense History\u003c/h3\u003e\n  \u003ctable id\u003d\"expenseTable\"\u003e\n    \u003cthead\u003e\n      \u003ctr\u003e\n        \u003cth\u003eDate\u003c/th\u003e\n        \u003cth\u003eCategory\u003c/th\u003e\n        \u003cth\u003eAmount\u003c/th\u003e\n        \u003cth\u003eNotes\u003c/th\u003e\n      \u003c/tr\u003e\n    \u003c/thead\u003e\n    \u003ctbody\u003e\u003c/tbody\u003e\n  \u003c/table\u003e\n\u003c/div\u003e\n\n\u003caudio id\u003d\"alertSound\"\u003e\n  \u003csource src\u003d\"https://actions.google.com/sounds/v1/alarms/beep_short.ogg\" type\u003d\"audio/ogg\"\u003e\n\u003c/audio\u003e\n\n\u003cscript\u003e\nlet expenses \u003d [];\nlet weeklyLimit \u003d Number(document.getElementById(\u0027weeklyLimit\u0027).value);\nlet expenseChart \u003d null;\nlet pieChart \u003d null;\n\nfunction setLimit() {\n  const val \u003d Number(document.getElementById(\u0027weeklyLimit\u0027).value);\n  if(isNaN(val) || val \u003c\u003d 0){ alert(\"Enter a valid weekly limit!\"); return; }\n  weeklyLimit \u003d val;\n  checkWeeklyLimit();\n}\n\nfunction addExpense() {\n  const date \u003d document.getElementById(\u0027date\u0027).value;\n  const amount \u003d Number(document.getElementById(\u0027amount\u0027).value);\n  const category \u003d document.getElementById(\u0027category\u0027).value;\n  const notes \u003d document.getElementById(\u0027notes\u0027).value;\n  if (!date || !amount) { alert(\u0027Date \u0026 Amount required\u0027); return; }\n  google.script.run.withSuccessHandler(loadExpenses).addExpense(date, amount, category, notes);\n}\n\nfunction loadExpenses() {\n  google.script.run.withSuccessHandler((data)\u003d\u003e{\n    expenses \u003d data;\n    if(expenses.length\u003d\u003d\u003d0){\n      resetCharts();\n      document.querySelector(\"#expenseTable tbody\").innerHTML \u003d \"\u003ctr\u003e\u003ctd colspan\u003d\u00274\u0027\u003eNo expenses yet\u003c/td\u003e\u003c/tr\u003e\";\n      document.getElementById(\u0027categoryTotals\u0027).innerHTML \u003d \"\";\n      return;\n    }\n    renderChart();\n    renderPie();\n    populateTable();\n    checkWeeklyLimit();\n    updateWeeklyComparison();\n  }).getExpenses();\n}\n\nfunction resetCharts(){\n  const ctx \u003d document.getElementById(\u0027expenseChart\u0027).getContext(\u00272d\u0027);\n  if(expenseChart) expenseChart.destroy();\n  ctx.clearRect(0,0,ctx.canvas.width,ctx.canvas.height);\n  ctx.font\u003d\"18px Arial\"; ctx.fillText(\"No expenses yet\", 50, 50);\n  const pie \u003d document.getElementById(\u0027pieChart\u0027).getContext(\u00272d\u0027);\n  if(pieChart) pieChart.destroy();\n  pie.clearRect(0,0,pie.canvas.width,pie.canvas.height);\n  pie.fillText(\"No expenses yet\",50,50);\n  document.getElementById(\u0027categoryTotals\u0027).innerHTML \u003d \"\";\n}\n\nfunction checkWeeklyLimit() {\n  const now \u003d new Date();\n  const day \u003d now.getDay();\n  const weekStart \u003d new Date(now); weekStart.setHours(0,0,0,0);\n  weekStart.setDate(now.getDate() - (day\u003d\u003d\u003d0?6:day-1));\n  let total \u003d 0;\n  expenses.forEach(e\u003d\u003e{ const d \u003d new Date(e.date); d.setHours(0,0,0,0); if(d\u003e\u003dweekStart \u0026\u0026 d\u003c\u003dnow) total +\u003d Number(e.amount); });\n  const warningDiv \u003d document.getElementById(\u0027warning\u0027);\n  const sound \u003d document.getElementById(\u0027alertSound\u0027);\n  if(total\u003eweeklyLimit){ warningDiv.style.display\u003d\u0027block\u0027; if(sound.paused) sound.play(); } \n  else{ warningDiv.style.display\u003d\u0027none\u0027; }\n}\n\nfunction updateWeeklyComparison(){\n  const now \u003d new Date();\n  const day \u003d now.getDay();\n  const thisWeekStart \u003d new Date(now); thisWeekStart.setHours(0,0,0,0);\n  thisWeekStart.setDate(now.getDate()-(day\u003d\u003d\u003d0?6:day-1));\n  const lastWeekStart \u003d new Date(thisWeekStart); lastWeekStart.setDate(thisWeekStart.getDate()-7);\n  let thisWeekTotal\u003d0, lastWeekTotal\u003d0;\n  expenses.forEach(e\u003d\u003e{\n    const d\u003dnew Date(e.date); d.setHours(0,0,0,0);\n    if(d\u003e\u003dthisWeekStart \u0026\u0026 d\u003c\u003dnow) thisWeekTotal+\u003dNumber(e.amount);\n    if(d\u003e\u003dlastWeekStart \u0026\u0026 d\u003cthisWeekStart) lastWeekTotal+\u003dNumber(e.amount);\n  });\n  const div \u003d document.getElementById(\"comparison\");\n  if(thisWeekTotal\u003elastWeekTotal){ div.innerHTML\u003d`📈 This week: RM${thisWeekTotal} vs Last week: RM${lastWeekTotal}`; div.className\u003d\"higher\"; }\n  else if(thisWeekTotal\u003clastWeekTotal){ div.innerHTML\u003d`📉 This week: RM${thisWeekTotal} vs Last week: RM${lastWeekTotal}`; div.className\u003d\"lower\"; }\n  else{ div.innerHTML\u003d`⚖ Same: RM${thisWeekTotal}`; div.className\u003d\"\"; }\n}\n\nfunction renderChart(){\n  const ctx \u003d document.getElementById(\u0027expenseChart\u0027).getContext(\u00272d\u0027);\n  const view \u003d document.getElementById(\u0027viewSelect\u0027).value;\n  let labels\u003d[], dataPoints\u003d[], backgroundColors\u003d[];\n  if(view\u003d\u003d\u003d\u0027daily\u0027){\n    const map\u003d{}; expenses.forEach(e\u003d\u003e{ map[e.date]\u003d(map[e.date]||0)+Number(e.amount); });\n    labels\u003dObject.keys(map); dataPoints\u003dObject.values(map);\n    backgroundColors \u003d dataPoints.map(v\u003d\u003ev\u003eweeklyLimit?\u0027rgba(255,99,71,0.8)\u0027:\u0027rgba(76,175,80,0.7)\u0027);\n  }\n  else if(view\u003d\u003d\u003d\u0027weekly\u0027){\n    const map\u003d{}; expenses.forEach(e\u003d\u003e{\n      const d\u003dnew Date(e.date); const day\u003dd.getDay(); const monday\u003dnew Date(d); monday.setDate(d.getDate()-(day\u003d\u003d\u003d0?6:day-1));\n      const wk \u003d monday.toISOString().slice(0,10); map[wk]\u003d(map[wk]||0)+Number(e.amount);\n    });\n    labels\u003dObject.keys(map); dataPoints\u003dObject.values(map);\n    backgroundColors \u003d dataPoints.map(v\u003d\u003ev\u003eweeklyLimit?\u0027rgba(255,99,71,0.8)\u0027:\u0027rgba(76,175,80,0.7)\u0027);\n  }\n  else if(view\u003d\u003d\u003d\u0027monthly\u0027){\n    const map\u003d{}; expenses.forEach(e\u003d\u003e{\n      const d\u003dnew Date(e.date); const mon\u003d`${d.getFullYear()}-${(\"0\"+(d.getMonth()+1)).slice(-2)}`;\n      map[mon]\u003d(map[mon]||0)+Number(e.amount);\n    });\n    labels\u003dObject.keys(map); dataPoints\u003dObject.values(map);\n    backgroundColors \u003d dataPoints.map(v\u003d\u003ev\u003eweeklyLimit?\u0027rgba(255,99,71,0.8)\u0027:\u0027rgba(76,175,80,0.7)\u0027);\n  }\n  if(expenseChart) expenseChart.destroy();\n  expenseChart\u003dnew Chart(ctx,{ type:\u0027bar\u0027, data:{ labels, datasets:[{ label:\"Expenses\", data:dataPoints, backgroundColor:backgroundColors, borderColor:backgroundColors.map(c\u003d\u003ec.replace(\u00270.7\u0027,\u00271\u0027).replace(\u00270.8\u0027,\u00271\u0027)), borderWidth:1 }] }, options:{ responsive:true, plugins:{ legend:{ display:false } } } });\n}\n\nfunction renderPie(){\n  const ctx\u003ddocument.getElementById(\u0027pieChart\u0027).getContext(\u00272d\u0027);\n  const map\u003d{}; expenses.forEach(e\u003d\u003e{ map[e.category]\u003d(map[e.category]||0)+Number(e.amount); });\n  const labels\u003dObject.keys(map); const values\u003dObject.values(map);\n  const colors\u003dlabels.map((_,i)\u003d\u003e`hsl(${i*50},70%,60%)`);\n  if(pieChart) pieChart.destroy();\n  pieChart\u003dnew Chart(ctx,{ type:\u0027pie\u0027, data:{ labels, datasets:[{ data:values, backgroundColor:colors }] }, options:{ plugins:{ legend:{ position:\u0027bottom\u0027 } } } });\n  let totalsHTML\u003d\"📊 Category Totals: \"; labels.forEach((cat,i)\u003d\u003e{ totalsHTML+\u003d`${cat}: ${values[i]} | `; });\n  document.getElementById(\u0027categoryTotals\u0027).innerHTML\u003dtotalsHTML.slice(0,-3);\n}\n\nfunction populateTable(){\n  const tbody\u003ddocument.querySelector(\"#expenseTable tbody\"); tbody.innerHTML\u003d\"\";\n  expenses.forEach(e\u003d\u003e{ tbody.innerHTML+\u003d`\u003ctr\u003e\u003ctd\u003e${e.date}\u003c/td\u003e\u003ctd\u003e${e.category}\u003c/td\u003e\u003ctd\u003eRM${e.amount}\u003c/td\u003e\u003ctd\u003e${e.notes}\u003c/td\u003e\u003c/tr\u003e`; });\n}\n\nfunction printExpenses(){\n  let printData\u003d\u0027\u0027; expenses.forEach(e\u003d\u003e{ printData+\u003d`${e.date} | ${e.category} | RM${e.amount} | ${e.notes}\\n`; });\n  const w\u003dwindow.open(\"\",\"\", \"height\u003d500,width\u003d800\"); w.document.write(\"\u003cpre\u003e\"+printData+\"\u003c/pre\u003e\"); w.print();\n}\n\nloadExpenses();\n\u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e\n"}]}